CLAUDE.local.md
AGENTS.override.md
.claude/settings.local.json
.claude/agent-memory/
.claude/scheduled_tasks.lock
.env
.env.*
*.pem
*.key
credentials.json

# UT-TDD runtime state
.ut-tdd/audit/*.jsonl
.ut-tdd/audit/escalation_state.json
.ut-tdd/cache/*
!.ut-tdd/cache/.gitkeep
.ut-tdd/state/*
!.ut-tdd/state/.gitkeep
.ut-tdd/handover/CURRENT.*
.ut-tdd/handover/*.bak
# Auto-generated CURRENT handover prose (regenerated each `ut-tdd handover`, mirrors the
# gitignored CURRENT.json, and currently embeds absolute local paths in its digest). It is
# runtime scratch — the canonical handover is harness.db feedback_events. Already-tracked
# historical handover docs stay tracked (gitignore never untracks). PLAN-L7-144 follow-up.
docs/handover/session-handover-*.md
.ut-tdd/logs/
.ut-tdd/adapters/local*.yaml
.ut-tdd/teams/local*.yaml
.ut-tdd/tmp/
# harness.db projection (runtime state, rebuildable from docs/state/logs; never tracked)
.ut-tdd/harness.db
.ut-tdd/harness.db-wal
.ut-tdd/harness.db-shm
# Codex 委譲タスク入力 (transient、PM が貼る目標プロンプト)
.ut-tdd/codex-tasks/
.tools/
# 外部 DL の設計テンプレ研究素材 (transient scratch、アーキ境界外・成果物でない)
downloads/

# HELIX runtime state
.helix/

# Python bytecode (旧 W1-W3a port の残骸。ADR-001 で TS rebuild、念のため残置)
__pycache__/
*.py[cod]
*$py.class

# PLAN frontmatter runtime lock (W1 cross-platform lock impl)
docs/plans/*.lock

# Node / TypeScript (UT-TDD harness core, ADR-001)
node_modules/
dist/
*.tsbuildinfo
coverage/
.vitest/

# OS / editor junk (Windows / macOS / Linux クロスプラットフォーム team)
.DS_Store
Thumbs.db
ehthumbs.db
*.swp
*~

# debug logs
*-debug.log
npm-debug.log*
bun-debug.log*
# 注: .vscode/ は共有設定 (settings.json / extensions.json) を commit したい場合があるため意図的に未 ignore (team 判断)
